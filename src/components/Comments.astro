---
import { AUTHOR_EMAIL } from "../consts.ts";
import Avatar from "./Avatar.astro";
import CommentCount from "./CommentCount.astro";
import CommentReplies from "./CommentReplies.astro";

type Props = {
  postSlug: string;
};

const { db } = Astro.locals;

// 从 db.query.comments.findMany 的返回类型推断单条评论类型
type RawCommentsArray = Awaited<ReturnType<typeof db.query.comments.findMany>>;
type RawComment = RawCommentsArray extends Array<infer T> ? T : never;
type CommentNode = RawComment & {
  replies: CommentNode[];
};

const { postSlug } = Astro.props;

const comments = await db.query.comments.findMany({
  where: (comments, { eq, and }) =>
    and(eq(comments.postSlug, postSlug), eq(comments.status, "public")),
  orderBy: (comments, { asc }) => [asc(comments.createdAt)]
});

// Build comment tree structure
const commentMap = new Map<number, CommentNode>();
const topLevelComments: CommentNode[] = [];

// First pass: create map of all comments
comments.forEach((comment) => {
  commentMap.set(comment.id, { ...comment, replies: [] });
});

// Second pass: build tree structure
comments.forEach((comment) => {
  if (!comment.parentId) {
    const node = commentMap.get(comment.id);
    if (node) {
      topLevelComments.push(node);
    }
  } else {
    const parent = commentMap.get(comment.parentId);
    const child = commentMap.get(comment.id);
    if (parent && child) {
      parent.replies.push(child);
    }
  }
});

// Sort replies by created_at
topLevelComments.forEach((comment) => {
  if (comment.replies) {
    comment.replies.sort(
      (a, b) =>
        new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime()
    );
  }
});
---

<section class="comment-section" id="comments">
  <h2 class="comment-title">
    // 评论列表 (<CommentCount postSlug={postSlug} server:defer />)
  </h2>
  <>
    {
      comments.length > 0 && (
        <ol>
          {topLevelComments.map((comment) => (
            <li class="comment-item">
              <article>
                <footer class="comment-head">
                  <Avatar
                    class="comment-avatar"
                    email={comment.authorEmail}
                    alt={comment.authorName}
                  />
                  <span class="comment-user">
                    {comment.authorName}
                    {comment.authorEmail === AUTHOR_EMAIL ? (
                      <span class="comment-author-badge">AUTHOR</span>
                    ) : (
                      ""
                    )}
                    {comment.authorWebsite ? (
                      <a
                        class="comment-website-link"
                        href={comment.authorWebsite}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        ☄
                      </a>
                    ) : (
                      ""
                    )}
                  </span>
                  <span class="comment-date">{comment.createdAt}</span>
                </footer>
                <p class="comment-body">{comment.content}</p>
                <button
                  type="button"
                  class="comment-reply-btn"
                  data-comment-id={comment.id}
                  data-comment-author={comment.authorName}
                >
                  回复
                </button>
                {comment.replies && comment.replies.length > 0 && (
                  <ol class="comment-replies">
                    <CommentReplies replies={comment.replies} />
                  </ol>
                )}
              </article>
            </li>
          ))}
        </ol>
      )
    }
  </>
</section>
