---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<div id="comment-section">
  <h2>发表评论</h2>
  <form id="comment-form">
    <div class="comment-section">
      <h3 id="comment-reply-title" style="display: none;"></h3>
      <button type="button" id="comment-cancel-reply" style="display:none;"
        >取消回复</button
      >

      <input type="hidden" name="s5s5_08" value={postSlug} />
      <input type="hidden" id="s5s5_yb-input" name="s5s5_yb" value="" />

      <div class="global-error error" id="global-error" style="display: none;">
      </div>

      <div class="form-group">
        <label for="s5s5_b9">内容 *</label>
        <textarea id="s5s5_b9" name="s5s5_b9" rows="5" required></textarea>
        <p class="error" id="error-s5s5_b9"></p>
      </div>

      <div class="form-group">
        <label for="s5s5_g5">昵称 *</label>
        <input type="text" id="s5s5_g5" name="s5s5_g5" required />
        <p class="error" id="error-s5s5_g5"></p>
      </div>

      <div class="form-group">
        <label for="s5s5_a6">邮箱 *</label>
        <input type="email" id="s5s5_a6" name="s5s5_a6" required />
        <p class="error" id="error-s5s5_a6"></p>
      </div>

      <div class="form-group">
        <label for="s5s5_0b">网站</label>
        <input type="url" id="s5s5_0b" name="s5s5_0b" />
        <p class="error" id="error-s5s5_0b"></p>
      </div>

      <button type="submit" id="submit-btn">提交评论</button>
    </div>
  </form>
</div>

<script>
  import { actions, isInputError } from "astro:actions";

  /**
   * 1. 集中管理 DOM 元素
   * 使用函数获取可以确保在脚本运行时元素存在，并方便复用
   */
  const elements = {
    form: document.getElementById("comment-form") as HTMLFormElement,
    container: document.getElementById("comment-section"),
    globalError: document.getElementById("global-error"),
    submitBtn: document.getElementById("submit-btn") as HTMLButtonElement,
    textarea: document.querySelector(
      "textarea[name='s5s5_b9']"
    ) as HTMLTextAreaElement,
    parentIdInput: document.getElementById("s5s5_yb-input") as HTMLInputElement,
    replyTitle: document.getElementById(
      "comment-reply-title"
    ) as HTMLHeadingElement,
    cancelBtn: document.getElementById(
      "comment-cancel-reply"
    ) as HTMLButtonElement
  };

  // 简单的空值检查，防止页面结构变化导致脚本崩溃
  if (elements.form) {
    initForm();
  }

  function initForm() {
    // 监听提交
    elements.form.addEventListener("submit", handleSubmit);

    // 监听取消回复
    elements.cancelBtn?.addEventListener("click", resetReplyState);

    // 监听点击“回复”按钮 (事件委托)
    document.addEventListener("click", handleReplyClick);
  }

  /**
   * 2. 处理表单提交逻辑
   */
  async function handleSubmit(e: SubmitEvent) {
    e.preventDefault();
    clearErrors();
    setSubmitting(true);

    const formData = new FormData(elements.form);

    // 处理父评论 ID (将空字符串转为 undefined，数字字符串转为 Number)
    const rawParentId = formData.get("s5s5_yb");
    const parentId = rawParentId ? Number(rawParentId) : undefined;

    const payload = {
      s5s5_08: formData.get("s5s5_08") as string,
      s5s5_g5: formData.get("s5s5_g5") as string,
      s5s5_a6: formData.get("s5s5_a6") as string,
      s5s5_0b: (formData.get("s5s5_0b") as string) || undefined,
      s5s5_b9: formData.get("s5s5_b9") as string,
      s5s5_yb: parentId
    };

    try {
      const { error } = await actions.comment.submit(payload);

      if (error) {
        if (isInputError(error)) {
          // 处理字段验证错误
          Object.entries(error.fields).forEach(([field, msgs]) => {
            showFieldError(field, msgs as string[]);
          });
        } else {
          // 处理全局错误 (如数据库连接失败)
          showGlobalError("提交失败: " + error.message);
        }
      } else {
        // 成功
        elements.form.reset();
        window.location.reload();
      }
    } catch (err) {
      console.error("Critical error:", err);
      showGlobalError("发生了意外错误，请稍后重试。");
    } finally {
      setSubmitting(false);
    }
  }

  /**
   * 3. 处理点击“回复”按钮
   */
  function handleReplyClick(e: MouseEvent) {
    const target = e.target as HTMLElement;
    // 查找最近的带 .comment-reply-btn 类的按钮
    const btn = target.closest(".comment-reply-btn") as HTMLButtonElement;

    if (!btn) return;

    const { commentId, commentAuthor } = btn.dataset;

    // 设置表单状态
    elements.parentIdInput.value = commentId || "";
    elements.textarea.value = `@${commentAuthor} `;
    elements.replyTitle.innerText = `回复给 ${commentAuthor}`;

    // UI 变更
    elements.replyTitle.style.display = "block";
    elements.cancelBtn.style.display = "inline";

    // 将表单移动到回复按钮下方
    btn.insertAdjacentElement("afterend", elements.form);

    // 聚焦输入框
    elements.textarea.focus();
  }

  /**
   * 4. 重置回复状态 (回到主楼)
   */
  function resetReplyState() {
    elements.parentIdInput.value = "";
    elements.textarea.value = "";
    elements.replyTitle.innerText = "";

    elements.replyTitle.style.display = "none";
    elements.cancelBtn.style.display = "none";

    // 将表单移回最底部的容器
    elements.container?.appendChild(elements.form);
  }

  // --- UI 辅助函数 ---

  function setSubmitting(isSubmitting: boolean) {
    if (elements.submitBtn) {
      elements.submitBtn.disabled = isSubmitting;
      elements.submitBtn.innerText = isSubmitting ? "提交中..." : "提交评论";
    }
  }

  function showGlobalError(msg: string) {
    if (elements.globalError) {
      elements.globalError.style.display = "block";
      elements.globalError.innerText = msg;
    }
  }

  function showFieldError(fieldName: string, messages: string[]) {
    const errorEl = document.getElementById(`error-${fieldName}`);
    if (errorEl) {
      errorEl.innerText = messages.join(", ");
    }
  }

  function clearErrors() {
    if (elements.globalError) {
      elements.globalError.style.display = "none";
      elements.globalError.innerText = "";
    }
    // 清空所有字段错误
    document.querySelectorAll(".error").forEach((el) => {
      if (el.id !== "global-error") el.innerHTML = "";
    });
  }
</script>

<style>
  /* 样式保持不变，略微增加一些 display 控制的平滑过渡 */
  .comment-section {
    max-width: 600px;
    margin: 2rem 0;
    padding: 1.5rem;
    border: 1px solid #eee;
    border-radius: 8px;
  }
  .form-group {
    margin-bottom: 1rem;
  }
  label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: bold;
  }
  input,
  textarea {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid #ccc;
    border-radius: 4px;
  }
  button {
    background-color: #333;
    color: white;
    padding: 0.5rem 1rem;
    border: none;
    cursor: pointer;
  }
  button:disabled {
    background-color: #999;
    cursor: not-allowed;
  }
  .error {
    color: red;
    font-size: 0.875rem;
    margin-top: 0.25rem;
    min-height: 1.2em; /* 预留位置防止抖动 */
  }
</style>
