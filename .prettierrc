{
  "trailingComma": "none",
  "plugins": [
    "prettier-plugin-sql",
    "prettier-plugin-astro",
    "@ianvs/prettier-plugin-sort-imports"
  ],
  "overrides": [
    {
      "files": "*.astro",
      "options": {
        "parser": "astro"
      }
    },
    {
      "files": "*.sql",
      "options": {
        "parser": "sql"
      }
    }
  ],
  "importOrder": [
    "<BUILTIN_MODULES>",
    "<THIRD_PARTY_MODULES>",
    "^astro",
    "^@/(.*)$",
    "^[../]",
    "^[./]",
    "^.+\\.s?css$"
  ]
}
