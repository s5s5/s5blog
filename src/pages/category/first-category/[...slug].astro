---
import { getCollection } from "astro:content";
import Pagination from "../../../components/Pagination.astro";
import PostCard from "../../../components/PostCard.astro";
import Layout from "../../../layouts/Layout.astro";
import {
  calculateTotalPages,
  getNextPageUrl,
  getPrevPageUrl,
  POSTS_PER_PAGE
} from "../../../utils/pagination";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter(
    (post) => post.data.category === "First Category"
  );
  const sortedPosts = posts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );
  const totalPages = calculateTotalPages(sortedPosts.length);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { slug: String(i + 1) },
    props: {
      page: i + 1,
      posts: sortedPosts.slice(i * POSTS_PER_PAGE, (i + 1) * POSTS_PER_PAGE),
      totalPages
    }
  }));
}

type Props = {
  page: number;
  posts: any[];
  totalPages: number;
};

const { page, posts, totalPages } = Astro.props;
const hasPrevPage = page > 1;
const hasNextPage = page < totalPages;
const prevPageUrl = getPrevPageUrl(page);
const nextPageUrl = getNextPageUrl(page);
---

<Layout title={`第 ${page} 页 / 共 ${totalPages} 页`}>
  {
    posts.map(async (post) => {
      return <PostCard post={post} isExcerpt />;
    })
  }

  <Pagination
    page={page}
    totalPages={totalPages}
    hasPrevPage={hasPrevPage}
    hasNextPage={hasNextPage}
    prevPageUrl={prevPageUrl}
    nextPageUrl={nextPageUrl}
  />
</Layout>
