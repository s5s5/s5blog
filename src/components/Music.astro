---
// Music files from public/music directory

import { CDN_URL } from "../consts.ts";

const musicFiles = [
  {
    name: "Auld Lang Syne - Ultimate Year End - Nhạc Giáng Sinh 2024 - AudioBay_BGM",
    file: `${CDN_URL}/assets/music/auld-lang-syne-ultimate-year-end-nhac-giang-sinh-2024-257349.mp3`
  },
  {
    name: "Solemn march - Icsilviu",
    file: `${CDN_URL}/assets/music/solemn-march-435533.mp3`
  },
  {
    name: "432Hz Magic Healing: Cosmic Sleep & Focus Frequency - vividillustrate",
    file: `${CDN_URL}/assets/music/432hz-magic-healing-cosmic-sleep-amp-focus-frequency-361117.mp3`
  }
];
---

<section>
  <h3 class="module-header">:: MUSIC</h3>
  <div class="cell-pad pod-container">
    <div class="pod-player">
      <div class="pod-screen">
        <marquee scrollamount="2" id="song-display">
          Song: {musicFiles[0].name}
        </marquee>
      </div>
      <audio id="audio-player" style="display: none;">
        <source src={musicFiles[0].file} type="audio/mpeg" />
      </audio>
      <div
        class="pod-wheel"
        id="music-player"
        data-music-files={JSON.stringify(musicFiles)}
      >
        <div class="pod-control-icon pod-top">MENU</div>
        <button
          type="button"
          class="pod-control-icon pod-bottom pod-active-btn"
          id="play-pause-btn"
          title="Play/Pause"
        >
          ▷
        </button>
        <button
          type="button"
          class="pod-control-icon pod-left pod-active-btn"
          id="prev-btn"
          title="Previous"
        >
          |&lt;
        </button>
        <button
          type="button"
          class="pod-control-icon pod-right pod-active-btn"
          id="next-btn"
          title="Next"
        >
          &gt;|
        </button>
        <div class="pod-btn-center"></div>
      </div>
    </div>
  </div>
</section>

<script>
  const player = document.getElementById(
    "audio-player"
  ) as HTMLAudioElement | null;
  const playPauseBtn = document.getElementById(
    "play-pause-btn"
  ) as HTMLButtonElement | null;
  const prevBtn = document.getElementById(
    "prev-btn"
  ) as HTMLButtonElement | null;
  const nextBtn = document.getElementById(
    "next-btn"
  ) as HTMLButtonElement | null;
  const songDisplay = document.getElementById(
    "song-display"
  ) as HTMLElement | null;
  const musicPlayerEl = document.getElementById("music-player");

  if (
    !player ||
    !playPauseBtn ||
    !prevBtn ||
    !nextBtn ||
    !songDisplay ||
    !musicPlayerEl
  ) {
    throw new Error("Required elements not found");
  }

  // Get musicFiles from dataset
  const musicFilesData = musicPlayerEl.dataset.musicFiles;
  if (!musicFilesData) {
    throw new Error("Music files data not found");
  }
  const musicFiles = JSON.parse(musicFilesData);

  let currentTrack = 0;
  let isPlaying = false;

  function updateDisplay() {
    const track = musicFiles[currentTrack];
    player!.src = track.file;
    songDisplay!.textContent = `Song: ${track.name}`;
  }

  function togglePlay() {
    if (isPlaying) {
      player!.pause();
      playPauseBtn!.textContent = "▷";
      isPlaying = false;
    } else {
      player!.play();
      playPauseBtn!.textContent = "||";
      isPlaying = true;
    }
  }

  function nextTrack() {
    currentTrack = (currentTrack + 1) % musicFiles.length;
    updateDisplay();
    if (isPlaying) {
      player!.play();
    }
  }

  function prevTrack() {
    currentTrack = (currentTrack - 1 + musicFiles.length) % musicFiles.length;
    updateDisplay();
    if (isPlaying) {
      player!.play();
    }
  }

  // Event listeners
  playPauseBtn!.addEventListener("click", togglePlay);
  nextBtn!.addEventListener("click", nextTrack);
  prevBtn!.addEventListener("click", prevTrack);

  // Auto play next track when current one ends
  player!.addEventListener("ended", nextTrack);

  // Initialize
  updateDisplay();
</script>

<style>
  /* Pod Player */
  .pod-container {
    background: var(--cell-bg-alt);
    padding: 10px;
  }
  .pod-player {
    background: var(--cell-bg);
    border: 1px solid var(--container-bg);
    border-radius: 4px;
    padding: 10px;
    box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.05);
    text-align: center;
  }
  .pod-screen {
    background: var(--cell-bg-alt);
    border: 1px solid var(--container-bg);
    border-radius: 2px;
    padding: 6px;
    margin-bottom: 10px;
    font-family: var(--font-pixel10);
    font-size: 10px;
    color: var(--text-muted);
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: inset 1px 1px 2px rgba(0, 0, 0, 0.05);
  }
  .pod-wheel {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--cell-bg-alt);
    border: 1px solid var(--container-bg);
    margin: 0 auto;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pod-btn-center {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--cell-bg);
    border: 1px solid var(--container-bg);
    box-shadow: 1px 1px 2px rgba(0, 0, 0, 0.1);
  }
  .pod-control-icon {
    position: absolute;
    font-size: 8px;
    color: var(--text-muted);
    font-family: var(--font-pixel8);
  }
  .pod-active-btn {
    background-color: transparent;
    border-radius: 2px;
    border: 1px solid transparent;
    cursor: pointer;
    width: 12px;
    height: 12px;
  }
  .pod-active-btn:hover {
    background-color: var(--cell-bg);
    border: 1px solid var(--container-bg);
    font-weight: bold;
  }
  .pod-top {
    top: 4px;
    left: 50%;
    transform: translateX(-50%);
  }
  .pod-bottom {
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
  }
  .pod-left {
    left: 3px;
    top: 50%;
    transform: translateY(-50%);
  }
  .pod-right {
    right: 3px;
    top: 50%;
    transform: translateY(-50%);
  }
</style>
