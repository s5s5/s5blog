---
type Props = {
  replies: CommentNode[];
};

const { replies } = Astro.props;

const { db } = Astro.locals;

// 从 db.query.comments.findMany 的返回类型推断单条评论类型
type RawCommentsArray = Awaited<ReturnType<typeof db.query.comments.findMany>>;
type RawComment = RawCommentsArray extends Array<infer T> ? T : never;
type CommentNode = RawComment & {
  replies: CommentNode[];
};
---

{
  replies && replies.length > 0 && (
    <>
      {replies.map((reply: CommentNode) => (
        <div class="comment">
          <p>
            <strong>{reply.authorName}</strong> at
            <time>{new Date(reply.createdAt).toLocaleString()}</time> 说:
          </p>
          <p>{reply.content}</p>
          {reply.replies && reply.replies.length > 0 && (
            <div class="comment-replies">
              <Astro.self replies={reply.replies} />
            </div>
          )}
        </div>
      ))}
    </>
  )
}

<style>
  .comment-replies {
    margin-top: 1rem;
    margin-left: 2rem;
    padding-left: 1rem;
    border-left: 2px solid #e0e0e0;
  }

  .comment-replies .comment {
    margin-top: 1rem;
    margin-bottom: 1rem;
  }

  .comment {
    padding: 1rem 0;
  }

  .comment p {
    margin: 0.5rem 0;
  }

  .comment strong {
    font-weight: 600;
  }

  .comment time {
    color: #666;
    font-size: 0.9em;
  }
</style>
