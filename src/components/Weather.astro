---
import { weatherData, type WeatherName } from "../utils/weather";

type Props = {
  weather: WeatherName;
};

const { weather } = Astro.props;

const { key, draw } = weatherData[weather];
const weatherLabel = `${weather} ${key.toUpperCase()}`;
---

<article-weather data-weather={key} data-draw={draw}>
  <figure class="post-hero">
    <canvas class="post-canvas"></canvas>
    <figcaption class="post-weather">
      {weatherLabel}
    </figcaption>
  </figure>
</article-weather>

<script>
  type ColorScheme = {
    bg: string;
    line: string;
    accent: string;
  };

  class ArticleWeather extends HTMLElement {
    weatherKey: string | null = null;
    drawType: string | null = null;

    connectedCallback() {
      this.weatherKey = this.getAttribute("data-weather");
      this.drawType = this.getAttribute("data-draw");
      this.initCanvas();
    }

    initCanvas() {
      const canvas = this.querySelector("canvas");
      if (!canvas) return;
      const container = canvas.parentElement;
      if (!container) return;

      const observer = new ResizeObserver(() => {
        this.draw(canvas as HTMLCanvasElement, container as HTMLElement);
      });
      observer.observe(container);

      requestAnimationFrame(() =>
        this.draw(canvas as HTMLCanvasElement, container as HTMLElement)
      );
    }

    getCSSVal(name: string): string {
      return getComputedStyle(document.documentElement)
        .getPropertyValue(name)
        .trim();
    }

    draw(canvas: HTMLCanvasElement, container: HTMLElement): void {
      if (!container || container.offsetWidth === 0) return;

      const colors: ColorScheme = {
        bg: this.getCSSVal("--canvas-bg"),
        line: this.getCSSVal("--canvas-line"),
        accent: this.getCSSVal("--canvas-accent")
      };

      const dpr = window.devicePixelRatio || 1;
      const rect = container.getBoundingClientRect();

      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;

      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(dpr, dpr);
      ctx.imageSmoothingEnabled = false;

      this.drawScene(ctx, rect.width, rect.height, colors);
    }

    drawScene(
      ctx: CanvasRenderingContext2D,
      w: number,
      h: number,
      colors: ColorScheme
    ): void {
      // 1. Background
      ctx.fillStyle = colors.bg;
      ctx.fillRect(0, 0, w, h);

      // 2. Ground
      const groundY = h - 20;
      ctx.fillStyle = colors.line;
      ctx.fillRect(0, groundY, w, 1);

      // Ground Noise
      for (let i = 0; i < w; i += 10) {
        if (Math.random() > 0.6) {
          const nw = Math.random() * 4 + 1;
          ctx.fillRect(i, groundY + 2 + Math.random() * 5, nw, 1);
        }
      }

      // 3. Weather Elements (Using draw / drawType)
      this.drawRetroWeather(ctx, w, h, this.drawType, colors);

      // 4. Scenery (Trees/Grass)
      const numProps = 2 + Math.floor(Math.random() * 3);
      for (let i = 0; i < numProps; i++) {
        let px = Math.random() * w;
        const ph = 10 + Math.random() * 15;
        const pw = 6 + Math.random() * 6;
        ctx.fillStyle = colors.line;
        ctx.fillRect(px, groundY - ph, pw, ph);
        // Simple detailing
        if (Math.random() > 0.5) {
          ctx.fillRect(px - 3, groundY - ph + 5, 3, 4);
          ctx.fillRect(px - 3, groundY - ph + 2, 1, 3);
        }
      }

      // 5. Entities
      const entityCount = 1 + Math.floor(Math.random() * 5);
      const types = ["human", "dog", "cat", "chicken", "bird"];

      // Always one hero
      this.drawPixelEntity(
        ctx,
        w * 0.2,
        groundY,
        colors.accent,
        types[Math.floor(Math.random() * types.length)]
      );

      // Others
      for (let i = 1; i < entityCount; i++) {
        const ex = Math.random() * (w - 40) + 20;
        const etype = types[Math.floor(Math.random() * types.length)];
        this.drawPixelEntity(ctx, ex, groundY, colors.line, etype);
      }

      // 6. UFO (Rare)
      if (Math.random() > 0.7) {
        this.drawUFO(
          ctx,
          Math.random() * w,
          Math.random() * (h * 0.3),
          colors.line
        );
      }
    }

    // =========================================
    // COMPOSABLE WEATHER DRAWING
    // =========================================
    drawRetroWeather(
      ctx: CanvasRenderingContext2D,
      w: number,
      h: number,
      type: string | null,
      colors: ColorScheme
    ): void {
      if (!type) type = "Sun";
      const t = type.toLowerCase().replace(/\s+/g, ""); // e.g. "sunbehindraincloud"

      // Analyze what to draw based on draw string inclusion
      // draw Examples: "Sun", "Sun With Small Cloud", "Sun Behind Rain Cloud",
      // "Cloud With Snow", "Cloud With Lightning And Rain"

      const hasSun = t.includes("sun");
      const hasCloud = t.includes("cloud") || t.includes("overcast");
      const hasRain = t.includes("rain") || t.includes("drizzle");
      const hasSnow =
        t.includes("snow") || t.includes("snowflake") || t.includes("ice");
      const hasLightning = t.includes("lightning") || t.includes("thunder");
      const hasFog = t.includes("fog");

      // "Small Cloud" implies lighter clouds
      const isSmallCloud = t.includes("smallcloud");

      // Draw Order: Sun -> Clouds -> Precipitation -> Fog -> Lightning

      // 1. SUN
      if (hasSun) {
        this.drawSun(ctx, w, h, colors);
      }

      // 2. CLOUDS
      if (hasCloud) {
        this.drawClouds(ctx, w, h, colors, isSmallCloud);
      }

      // 3. PRECIPITATION
      if (hasRain) {
        this.drawRain(ctx, w, h, colors);
      }
      if (hasSnow) {
        this.drawSnow(ctx, w, h, colors);
      }

      // 4. FOG
      if (hasFog) {
        this.drawFog(ctx, w, h, colors);
      }

      // 5. LIGHTNING
      if (hasLightning) {
        this.drawLightning(ctx, w, h, colors);
      }
    }

    // --- Elemental Drawing Functions ---

    drawSun(
      ctx: CanvasRenderingContext2D,
      w: number,
      h: number,
      colors: ColorScheme
    ): void {
      const sunX = w - 50;
      const sunY = 40;
      ctx.fillStyle = colors.accent;
      ctx.fillRect(sunX, sunY, 12, 12);

      // Rays
      ctx.fillStyle = colors.line;
      // In "Sun Behind..." we might want the sun to be the accent color still,
      // but maybe the rays are less visible? Stick to standard retro sun.
      const gap = 4;
      // Cardinal
      ctx.fillRect(sunX + 5, sunY - 6 - gap, 2, 3);
      ctx.fillRect(sunX + 5, sunY + 15 + gap, 2, 3);
      ctx.fillRect(sunX - 6 - gap, sunY + 5, 3, 2);
      ctx.fillRect(sunX + 15 + gap, sunY + 5, 3, 2);
      // Diagonal
      const diagGap = 3;
      ctx.fillRect(sunX - 3 - diagGap, sunY - 3 - diagGap, 2, 2);
      ctx.fillRect(sunX + 13 + diagGap, sunY - 3 - diagGap, 2, 2);
      ctx.fillRect(sunX - 3 - diagGap, sunY + 13 + diagGap, 2, 2);
      ctx.fillRect(sunX + 13 + diagGap, sunY + 13 + diagGap, 2, 2);
    }

    drawClouds(
      ctx: CanvasRenderingContext2D,
      w: number,
      h: number,
      colors: ColorScheme,
      isSmall: boolean
    ): void {
      const count = isSmall ? 3 : 8; // Fewer clouds for "Small Cloud"
      ctx.fillStyle = colors.line;

      // If it's "Small Cloud", maybe keep them high and transparent
      // If it's "Cloud" (Overcast), make them dense
      ctx.globalAlpha = isSmall ? 0.6 : 0.25;

      for (let i = 0; i < count; i++) {
        let cx = Math.random() * w;
        let cy = Math.random() * (h * 0.4); // Keep in top 40%
        let cw = (isSmall ? 20 : 40) + Math.random() * 30;

        // Main cloud body
        ctx.fillRect(cx, cy, cw, 10);
        // Details to make it look blocky/retro
        ctx.fillRect(cx + 8, cy - 6, cw - 16, 6);
        ctx.fillRect(cx + 4, cy + 4, cw - 12, 4);
      }

      // If Overcast/Heavy cloud, add some horizon lines
      if (!isSmall) {
        ctx.globalAlpha = 0.4;
        for (let i = 0; i < 10; i++) {
          ctx.fillRect(
            Math.random() * w,
            Math.random() * (h * 0.5),
            Math.random() * 60 + 20,
            2
          );
        }
      }
      ctx.globalAlpha = 1.0;
    }

    drawRain(
      ctx: CanvasRenderingContext2D,
      w: number,
      h: number,
      colors: ColorScheme
    ): void {
      ctx.fillStyle = colors.line;
      for (let i = 0; i < 50; i++) {
        const rx = Math.random() * w;
        const ry = Math.random() * h;
        ctx.fillRect(rx, ry, 1, 5); // Vertical rain drops
      }
    }

    drawSnow(
      ctx: CanvasRenderingContext2D,
      w: number,
      h: number,
      colors: ColorScheme
    ): void {
      const isDark =
        document.documentElement.getAttribute("data-theme") === "dark" ||
        colors.bg.includes("#202124") ||
        colors.bg.includes("#111");
      ctx.fillStyle = isDark ? "#fff" : "#ccc";

      for (let i = 0; i < 60; i++) {
        const sx = Math.random() * w;
        const sy = Math.random() * h;
        // Simple 2x2 pixel snowflakes
        ctx.fillRect(sx, sy, 2, 2);
      }
    }

    drawFog(
      ctx: CanvasRenderingContext2D,
      w: number,
      h: number,
      colors: ColorScheme
    ): void {
      ctx.fillStyle = colors.line;
      ctx.globalAlpha = 0.15;
      // Vertical stripes for fog effect
      for (let x = 0; x < w; x += 3) {
        if (Math.random() > 0.5) {
          ctx.fillRect(x, 0, 1, h);
        }
      }
      ctx.globalAlpha = 1.0;
    }

    drawLightning(
      ctx: CanvasRenderingContext2D,
      w: number,
      h: number,
      colors: ColorScheme
    ): void {
      ctx.strokeStyle = colors.accent;
      ctx.lineWidth = 2;
      ctx.beginPath();
      let lx = Math.random() * w;
      let ly = 10;
      ctx.moveTo(lx, ly);

      while (ly < h - 30) {
        lx += (Math.random() - 0.5) * 40; // Zig zag
        ly += 15 + Math.random() * 10;
        ctx.lineTo(lx, ly);
      }
      ctx.stroke();
    }

    // --- Entity Drawing (Unchanged but modularized in main flow) ---
    drawUFO(
      ctx: CanvasRenderingContext2D,
      x: number,
      y: number,
      color: string
    ): void {
      ctx.fillStyle = color;
      const size = 3;
      ctx.fillRect(x + 2 * size, y, 4 * size, 2 * size);
      ctx.fillRect(x, y + 2 * size, 8 * size, 2 * size);
      ctx.clearRect(x + size, y + 3 * size, size, size / 2);
      ctx.clearRect(x + 3 * size, y + 3 * size, size, size / 2);
      ctx.clearRect(x + 6 * size, y + 3 * size, size, size / 2);
    }

    drawPixelEntity(
      ctx: CanvasRenderingContext2D,
      x: number,
      y: number,
      color: string,
      type: string
    ): void {
      const size = 3;
      ctx.fillStyle = color;
      ctx.strokeStyle = color;
      ctx.lineWidth = size;
      ctx.lineCap = "round";
      ctx.lineJoin = "round";
      const r = (dx: number, dy: number, w: number, h: number) =>
        ctx.fillRect(x + dx * size, y - dy * size, w * size, h * size);

      if (type === "human") {
        const pose = Math.floor(Math.random() * 3);
        const dir = Math.random() > 0.5 ? 1 : -1;
        const headCx = x + 2.5 * size;
        const headCy = y - 11 * size;
        const neckY = headCy + 1.5 * size;
        const hipY = y - 5 * size;
        const shoulderX = headCx + (pose > 0 ? dir * 2 * size : 0);
        const shoulderY = neckY + size;

        ctx.beginPath();
        ctx.arc(headCx, headCy, 1.5 * size, 0, Math.PI * 2);
        ctx.fill();

        ctx.beginPath();
        ctx.moveTo(shoulderX, neckY);
        ctx.lineTo(headCx, hipY);
        ctx.stroke();

        // Legs & Arms (Simplified logic from previous version)
        if (pose === 0) {
          // Stand
          ctx.beginPath();
          ctx.moveTo(headCx, hipY);
          ctx.lineTo(headCx, y);
          ctx.stroke();
          ctx.beginPath();
          ctx.moveTo(shoulderX, shoulderY);
          ctx.lineTo(
            shoulderX + (Math.random() > 0.5 ? 6 : -2) * size,
            shoulderY + (Math.random() > 0.5 ? 0 : 6) * size
          );
          ctx.stroke(); // Random arm
        } else {
          // Run
          ctx.beginPath();
          ctx.moveTo(headCx, hipY);
          ctx.lineTo(headCx - dir * 3 * size, hipY + 2 * size);
          ctx.lineTo(headCx - dir * 4 * size, y - 2 * size);
          ctx.moveTo(headCx, hipY);
          ctx.lineTo(headCx + dir * 2 * size, hipY + size);
          ctx.lineTo(headCx + dir * 2 * size, y);
          ctx.stroke();
          ctx.beginPath();
          ctx.moveTo(shoulderX, shoulderY);
          ctx.lineTo(shoulderX + dir * 3 * size, shoulderY - 2 * size);
          ctx.moveTo(shoulderX, shoulderY);
          ctx.lineTo(shoulderX - dir * 2 * size, shoulderY + 2 * size);
          ctx.stroke();
        }
      } else if (type === "dog") {
        r(0, 6, 3, 3);
        r(0, 8, 1, 2);
        r(2, 6, 6, 3);
        r(7, 7, 1, 2);
        r(2, 3, 1, 3);
        r(6, 3, 1, 3);
      } else if (type === "cat") {
        r(0, 6, 3, 3);
        r(0, 8, 1, 2);
        r(2, 8, 1, 2);
        r(2, 5, 5, 3);
        r(6, 6, 1, 4);
        r(2, 2, 1, 2);
        r(5, 2, 1, 2);
      } else if (type === "chicken") {
        r(0, 4, 2, 2);
        r(1, 4, 1, 1);
        r(0, 3, 3, 2);
        r(1, 1, 1, 1);
      } else if (type === "bird") {
        const flyY = y - 30 - Math.random() * 20;
        ctx.fillRect(x, flyY, 4 * size, size);
        ctx.fillRect(x + size, flyY - size, size, 3 * size);
      }
      ctx.beginPath();
    }
  }

  // Register Web Component
  customElements.define("article-weather", ArticleWeather);
</script>

<style>
  .post-hero {
    width: 100%;
    height: 220px;
    overflow: hidden;
    position: relative;
    background: var(--cell-bg-alt);
    border-bottom: 1px solid var(--container-bg);
  }
  .post-canvas {
    width: 100%;
    height: 100%;
    display: block;
    image-rendering: pixelated;
    filter: none;
  }
  .post-canvas:hover {
    filter: hue-rotate(185deg);
  }
  .post-weather {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--text-main);
    color: var(--cell-bg);
    padding: 3px 10px;
    font-size: 10px;
    font-family: var(--font-pixel10);
    border: 1px solid var(--cell-bg);
    z-index: 2;
    box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.5);
    pointer-events: none;
  }
</style>
