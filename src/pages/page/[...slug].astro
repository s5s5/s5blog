---
import { getCollection, render } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import Pagination from "../../components/Pagination.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import {
  calculateTotalPages,
  getNextPageUrl,
  getPrevPageUrl,
  POSTS_PER_PAGE
} from "../../utils/pagination";

type Props = {
  page: number;
  posts: any[];
  totalPages: number;
};

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const sortedPosts = posts.sort((a, b) => Number(b.id) - Number(a.id));
  const totalPages = calculateTotalPages(sortedPosts.length);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { slug: String(i + 1) },
    props: {
      page: i + 1,
      posts: sortedPosts.slice(i * POSTS_PER_PAGE, (i + 1) * POSTS_PER_PAGE),
      totalPages
    }
  }));
}

const { page, posts, totalPages } = Astro.props;
const hasPrevPage = page > 1;
const hasNextPage = page < totalPages;
const prevPageUrl = getPrevPageUrl(page);
const nextPageUrl = getNextPageUrl(page);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead
      title={`${SITE_TITLE} - 第 ${page} 页`}
      description={SITE_DESCRIPTION}
    />
  </head>
  <body>
    <Header />
    <main>
      <section>
        {
          posts.map(async (post) => {
            const { Content } = await render(post);
            return (
              <article>
                <h2>
                  <a href={`/${post.id}`}>{post.data.title}</a>
                </h2>
                <div>
                  <span class="author">s5s5</span>
                  <FormattedDate date={post.data.pubDate} />
                  {post.data.category && (
                    <span class="category">{post.data.category}</span>
                  )}
                </div>
                <div class="excerpt">
                  <Content />
                </div>
                <a href={`/${post.id}`} class="read-more">
                  继续阅读 →
                </a>
                <hr />
              </article>
            );
          })
        }
      </section>

      <Pagination
        page={page}
        totalPages={totalPages}
        hasPrevPage={hasPrevPage}
        hasNextPage={hasNextPage}
        prevPageUrl={prevPageUrl}
        nextPageUrl={nextPageUrl}
      />
    </main>
    <Footer />
  </body>
</html>

<style>
  .excerpt {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .excerpt :global(p:first-child) {
    margin-top: 0;
  }

  .read-more {
    display: inline-block;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.3s ease;
  }

  .read-more:hover {
    opacity: 0.7;
    text-decoration: underline;
  }
</style>
