---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<section id="comment-form" class="comment-form">
  <form class="form" id="form">
    <input type="hidden" name="s5s5_08" value={postSlug} />
    <input type="hidden" id="s5s5_yb-input" name="s5s5_yb" value="" />
    <label class="form-name-label">
      <input type="text" id="name" name="name" placeholder="Name" />
    </label>

    <div class="form-label">
      <h3 id="comment-reply-title">发表评论：</h3>
      <button
        type="button"
        id="comment-cancel-reply"
        class="comment-cancel-reply"
        style="display:none;"
      >
        取消回复
      </button>
    </div>

    <label>
      <textarea
        id="s5s5_b9"
        name="s5s5_b9"
        rows="5"
        required
        maxlength="2000"
        minlength="1"
        class="form-input"
        placeholder="⸜(｡˃ ᵕ ˂ )⸝♡ ..."></textarea>
    </label>

    <div class="form-row">
      <label>
        <input
          type="text"
          id="s5s5_g5"
          name="s5s5_g5"
          required
          maxlength="50"
          class="form-input"
          placeholder="☺ 署名"
        />
      </label>
      <label>
        <input
          type="email"
          id="s5s5_a6"
          name="s5s5_a6"
          required
          maxlength="255"
          class="form-input"
          placeholder="✉ 邮件 (不会公开)"
        />
      </label>
    </div>
    <div class="form-row">
      <label>
        <input
          type="url"
          id="s5s5_0b"
          name="s5s5_0b"
          maxlength="500"
          class="form-input"
          placeholder="☄ 网站 (选填)"
        />
      </label>
      <button type="submit" class="form-submit" id="submit-btn">
        发表评论
      </button>
    </div>
    <div class="global-error error" id="global-error" style="display: none;">
    </div>
    <p class="error" id="error-s5s5_b9"></p>
    <p class="error" id="error-s5s5_g5"></p>
    <p class="error" id="error-s5s5_a6"></p>
    <p class="error" id="error-s5s5_0b"></p>
  </form>
</section>

<script>
  import { actions, isInputError } from "astro:actions";

  /**
   * 1. 集中管理 DOM 元素
   * 为了兼容 View Transitions，使用函数获取元素以支持动态更新
   */
  function getElements() {
    return {
      form: document.getElementById("form") as HTMLFormElement,
      container: document.getElementById("comment-form"),
      globalError: document.getElementById("global-error"),
      submitBtn: document.getElementById("submit-btn") as HTMLButtonElement,
      textarea: document.querySelector(
        "textarea[name='s5s5_b9']"
      ) as HTMLTextAreaElement,
      parentIdInput: document.getElementById(
        "s5s5_yb-input"
      ) as HTMLInputElement,
      replyTitle: document.getElementById(
        "comment-reply-title"
      ) as HTMLHeadingElement,
      cancelBtn: document.getElementById(
        "comment-cancel-reply"
      ) as HTMLButtonElement
    };
  }

  let elements = getElements();

  // 用于存储事件监听器，以便在 View Transitions 中正确移除和重新绑定
  let formSubmitListener: ((e: SubmitEvent) => void) | null = null;
  let cancelReplyListener: (() => void) | null = null;
  let replyClickListener: ((e: MouseEvent) => void) | null = null;

  function initForm() {
    elements = getElements();

    if (!elements.form) return;

    // 移除旧的事件监听器（防止重复绑定）
    if (formSubmitListener) {
      elements.form.removeEventListener("submit", formSubmitListener);
    }
    if (cancelReplyListener && elements.cancelBtn) {
      elements.cancelBtn.removeEventListener("click", cancelReplyListener);
    }
    if (replyClickListener) {
      document.removeEventListener("click", replyClickListener);
    }

    // 创建新的事件监听器
    formSubmitListener = (e: SubmitEvent) => handleSubmit(e);
    cancelReplyListener = () => resetReplyState();
    replyClickListener = (e: MouseEvent) => handleReplyClick(e);

    // 监听提交
    elements.form.addEventListener("submit", formSubmitListener);

    // 监听取消回复
    elements.cancelBtn?.addEventListener("click", cancelReplyListener);

    // 监听点击"回复"按钮 (事件委托)
    document.addEventListener("click", replyClickListener);
  }

  /**
   * 2. 处理表单提交逻辑
   */
  async function handleSubmit(e: SubmitEvent) {
    e.preventDefault();
    clearErrors();
    setSubmitting(true);

    const formData = new FormData(elements.form);

    // 处理父评论 ID (将空字符串转为 undefined，数字字符串转为 Number)
    const rawParentId = formData.get("s5s5_yb");
    const parentId = rawParentId ? Number(rawParentId) : undefined;

    const payload = {
      name: (formData.get("name") as string) || undefined,
      s5s5_08: formData.get("s5s5_08") as string,
      s5s5_g5: formData.get("s5s5_g5") as string,
      s5s5_a6: formData.get("s5s5_a6") as string,
      s5s5_0b: (formData.get("s5s5_0b") as string) || undefined,
      s5s5_b9: formData.get("s5s5_b9") as string,
      s5s5_yb: parentId
    };

    try {
      const result = await actions.comment.submit(payload);

      if (result.error) {
        if (isInputError(result.error)) {
          // 处理字段验证错误
          Object.entries(result.error.fields).forEach(([field, msgs]) => {
            showFieldError(field, msgs as string[]);
          });
        } else {
          // 处理全局错误 (如数据库连接失败)
          showGlobalError("提交失败: " + result.error.message);
        }
      } else {
        // 成功
        elements.form.reset();
        // 刷新页面并跳转到评论区域
        window.location.hash = "#comment-" + result.data.comment?.id;
        window.location.reload();
      }
    } catch (err) {
      console.error("Critical error:", err);
      showGlobalError("发生了意外错误，请稍后重试。");
    } finally {
      setSubmitting(false);
    }
  }

  /**
   * 3. 处理点击“回复”按钮
   */
  function handleReplyClick(e: MouseEvent) {
    const target = e.target as HTMLElement;
    // 查找最近的带 .comment-reply-btn 类的按钮
    const btn = target.closest(".comment-reply-btn") as HTMLButtonElement;

    if (!btn) return;

    const { commentId, commentAuthor } = btn.dataset;

    // 设置表单状态
    elements.parentIdInput.value = commentId || "";
    elements.textarea.value = `@${commentAuthor} `;
    elements.replyTitle.innerText = `回复给 ${commentAuthor}`;

    // UI 变更
    elements.cancelBtn.style.display = "inline";

    // 将表单移动到回复按钮下方
    btn.insertAdjacentElement("afterend", elements.form);

    // 聚焦输入框
    elements.textarea.focus();
  }

  /**
   * 4. 重置回复状态 (回到主楼)
   */
  function resetReplyState() {
    elements.parentIdInput.value = "";
    elements.textarea.value = "";
    elements.replyTitle.innerText = "发表评论：";

    elements.cancelBtn.style.display = "none";

    // 将表单移回最底部的容器
    elements.container?.appendChild(elements.form);
  }

  // --- UI 辅助函数 ---

  function setSubmitting(isSubmitting: boolean) {
    if (elements.submitBtn) {
      elements.submitBtn.disabled = isSubmitting;
      elements.submitBtn.innerText = isSubmitting ? "提交中..." : "提交评论";
    }
  }

  function showGlobalError(msg: string) {
    if (elements.globalError) {
      elements.globalError.style.display = "block";
      elements.globalError.innerText = msg;
    }
  }

  function showFieldError(fieldName: string, messages: string[]) {
    const errorEl = document.getElementById(`error-${fieldName}`);
    if (errorEl) {
      errorEl.innerText = messages.join(", ");
    }
  }

  function clearErrors() {
    if (elements.globalError) {
      elements.globalError.style.display = "none";
      elements.globalError.innerText = "";
    }
    // 清空所有字段错误
    document.querySelectorAll(".error").forEach((el) => {
      if (el.id !== "global-error") el.innerHTML = "";
    });
  }

  // 处理 URL 中的评论锚点滚动
  function handleCommentAnchorScroll() {
    const hash = window.location.hash;
    if (hash === "#comments") {
      // 滚动到评论区域
      setTimeout(() => {
        const commentsSection = document.getElementById("comments");
        if (commentsSection) {
          commentsSection.scrollIntoView({
            behavior: "smooth",
            block: "start"
          });
        }
      }, 1);
    } else if (hash.startsWith("#comment-")) {
      // 滚动到具体评论
      setTimeout(() => {
        const commentId = hash.substring("#comment-".length);
        const commentElement = document.getElementById(`comment-${commentId}`);
        if (commentElement) {
          commentElement.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      }, 1);
    }
  }

  // 初始化表单
  initForm();

  // 兼容 View Transitions API
  // astro:after-swap 在页面 swap 完成后触发，此时 DOM 已更新
  // astro:page-load 在初始页面加载和导航后都会触发
  document.addEventListener("astro:after-swap", () => {
    initForm();
    // View Transitions 时使用更长的延迟确保动画完成
    setTimeout(() => {
      handleCommentAnchorScroll();
    }, 200);
  });
  document.addEventListener("astro:page-load", () => {
    initForm();
    handleCommentAnchorScroll();
  });

  // 页面初始加载时也处理锚点
  handleCommentAnchorScroll();
</script>

<style>
  .comment-form {
    padding-bottom: 20px;
    padding-left: 20px;
    padding-right: 20px;
    background: var(--cell-bg);
  }
  .form {
    background: var(--cell-bg-alt);
    padding: 15px;
    border: 1px solid var(--container-bg);
  }
  .form-label {
    font-weight: normal;
    font-family: var(--font-pixel10);
    font-size: 10px;
    letter-spacing: 1px;
    margin-bottom: 8px;
    color: var(--text-muted);
  }
  .form-label h3 {
    font-weight: inherit;
    font-family: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    display: inline;
  }
  .comment-cancel-reply {
    background: none;
    border: none;
    color: var(--link-color);
    font-family: var(--font-pixel10);
    font-size: 10px;
    letter-spacing: 1px;
    cursor: pointer;
    margin-left: 10px;
  }
  .comment-cancel-reply:hover {
    color: var(--link-hover);
    text-decoration: underline;
  }
  .form-row {
    display: flex;
    gap: 10px;
    margin-bottom: 8px;
  }
  .form-row label {
    flex: 1;
  }
  .form-input {
    flex: 1;
    border: 1px solid var(--container-bg);
    padding: 6px;
    font-size: 12px;
    font-family: var(--font-pixel12);
    letter-spacing: 2px;
    background: var(--cell-bg);
    color: var(--text-main);
    width: 100%;
  }
  .form-input::placeholder {
    font-family: var(--font-pixel10);
    font-size: 10px;
    letter-spacing: 1px;
  }
  textarea.form-input {
    width: 100%;
    margin-bottom: 8px;
    height: 60px;
  }
  .form-submit {
    background: var(--highlight);
    border: 1px solid var(--border-color);
    color: var(--highlight-text);
    padding: 0 20px;
    cursor: pointer;
    font-family: var(--font-pixel10);
    font-size: 10px;
    letter-spacing: 3px;
    font-weight: bold;
    flex: 0 0 auto;
    box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.1);
  }
  .form-submit:hover {
    background: var(--cell-bg);
    color: var(--text-main);
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 rgba(0, 0, 0, 0.1);
  }
  .form-name-label {
    position: absolute;
    top: -9999px;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .error {
    color: var(--canvas-accent);
    font-size: 10px;
    font-family: var(--font-pixel10);
  }
</style>
