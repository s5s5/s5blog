<section>
  <h3 class="module-header">:: SETTINGS</h3>
  <div class="cell-pad">
    <button type="button" id="theme-toggle" class="theme-btn">
      THEME: AUTO
    </button>
  </div>
</section>

<script>
  // --- THEME LOGIC ---
  function initializeTheme() {
    const themeBtn = document.getElementById(
      "theme-toggle"
    ) as HTMLButtonElement | null;
    const htmlEl = document.documentElement;
    let currentThemeMode = localStorage.getItem("themeMode") || "auto";

    function getSystemTheme(): "light" | "dark" {
      return window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    }

    const systemTheme = getSystemTheme();
    const themeModes: string[] =
      systemTheme === "dark"
        ? ["auto", "light", "dark"]
        : ["auto", "dark", "light"];

    function getEffectiveTheme(): "light" | "dark" {
      if (currentThemeMode === "auto") {
        return getSystemTheme();
      }
      return currentThemeMode as "light" | "dark";
    }

    function applyTheme() {
      const effectiveTheme = getEffectiveTheme();
      if (effectiveTheme === "dark") {
        htmlEl.setAttribute("data-theme", "dark");
      } else {
        htmlEl.removeAttribute("data-theme");
      }
      if (themeBtn) {
        themeBtn.innerText = "THEME: " + currentThemeMode.toUpperCase();
      }
      // setTimeout(redrawAllCanvases, 50);
    }

    if (themeBtn) {
      themeBtn.addEventListener("click", () => {
        const currentIndex = themeModes.indexOf(currentThemeMode);
        const nextIndex = (currentIndex + 1) % themeModes.length;
        currentThemeMode = themeModes[nextIndex];
        localStorage.setItem("themeMode", currentThemeMode);
        applyTheme();
      });
    }

    if (currentThemeMode === "auto") {
      window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", applyTheme);
    }

    applyTheme();
  }

  // Initialize on first load
  initializeTheme();

  // Re-initialize on view transitions
  document.addEventListener("astro:after-swap", initializeTheme);
</script>

<style>
  /* Theme Toggle */
  .theme-btn {
    width: 100%;
    background: var(--cell-bg);
    border: 1px solid var(--container-bg);
    color: var(--text-main);
    padding: 4px;
    font-family: var(--font-mono), monospace;
    font-size: 10px;
    cursor: pointer;
  }
  .theme-btn:hover {
    background: var(--highlight);
    color: var(--highlight-text);
    border-color: var(--border-color);
  }
</style>
