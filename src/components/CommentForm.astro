---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<div id="comment-section">
  <h2>发表评论</h2>
  <form id="comment-form">
    <div class="comment-section">
      <h3 id="reply-title" style="display: none;"></h3>
      <button type="button" id="comment-cancel-reply" style="display:none;"
        >取消回复</button
      >

      <input type="hidden" name="s5s5_08" value={postSlug} />
      <input type="hidden" id="s5s5_yb-input" name="s5s5_yb" value="" />

      <div class="global-error error" id="global-error" style="display: none;">
      </div>

      <div class="form-group">
        <label for="s5s5_b9">内容 *</label>
        <textarea id="s5s5_b9" name="s5s5_b9" rows="5" required></textarea>
        <p class="error" id="error-s5s5_b9"></p>
      </div>

      <div class="form-group">
        <label for="s5s5_g5">昵称 *</label>
        <input type="text" id="s5s5_g5" name="s5s5_g5" required />
        <p class="error" id="error-s5s5_g5"></p>
      </div>

      <div class="form-group">
        <label for="s5s5_a6">邮箱 *</label>
        <input type="email" id="s5s5_a6" name="s5s5_a6" required />
        <p class="error" id="error-s5s5_a6"></p>
      </div>

      <div class="form-group">
        <label for="s5s5_0b">网站</label>
        <input type="url" id="s5s5_0b" name="s5s5_0b" />
        <p class="error" id="error-s5s5_0b"></p>
      </div>

      <button type="submit" id="submit-btn">提交评论</button>
    </div>
  </form>
</div>

<script>
  import { actions, isInputError } from "astro:actions";

  const form = document.getElementById("comment-form") as HTMLFormElement;
  const globalError = document.getElementById("global-error");
  const textarea = form.querySelector("textarea") as HTMLTextAreaElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const parentIdInput = document.getElementById(
    "s5s5_yb-input"
  ) as HTMLInputElement;
  const replyTitle = document.getElementById(
    "reply-title"
  ) as HTMLHeadingElement;
  const cancelBtn = document.getElementById(
    "comment-cancel-reply"
  ) as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrors();
    submitBtn.disabled = true;
    submitBtn.innerText = "提交中...";

    const formData = new FormData(form);
    const s5s5_ybRaw = formData.get("s5s5_yb");
    const s5s5_ybVal =
      s5s5_ybRaw && s5s5_ybRaw !== "" ? Number(s5s5_ybRaw) : undefined;

    const payload = {
      s5s5_08: formData.get("s5s5_08") as string,
      s5s5_g5: formData.get("s5s5_g5") as string,
      s5s5_a6: formData.get("s5s5_a6") as string,
      s5s5_0b: (formData.get("s5s5_0b") as string) || undefined,
      s5s5_b9: formData.get("s5s5_b9") as string,
      s5s5_yb: s5s5_ybVal
    };

    try {
      const { error } = await actions.comment.submit(payload);

      if (error) {
        if (isInputError(error)) {
          Object.entries(error.fields).forEach(([fieldName, messages]) => {
            showFieldError(fieldName, messages as string[]);
          });
        } else {
          globalError!.style.display = "block";
          globalError!.innerText = "提交失败: " + error.message;
        }
      } else {
        form.reset();
        window.location.reload();
      }
    } catch (err) {
      console.error("Unexpected error:", err);
      globalError!.style.display = "block";
      globalError!.innerText = "发生了意外错误。";
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerText = "提交评论";
    }
  });

  // 1. 监听所有回复按钮（委托模式）
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLButtonElement)?.closest(".comment-reply-btn");
    if (!btn) return;

    const commentId = (btn as HTMLButtonElement | null)?.dataset?.commentId;
    const commentAuthor = (btn as HTMLButtonElement | null)?.dataset
      ?.commentAuthor;
    parentIdInput.value = commentId ?? ""; // 设置为回复某条评论
    textarea.value = `@${commentAuthor} `; // 提示回复对象
    replyTitle.innerText = `回复给 ${commentAuthor}`;
    replyTitle.style.display = "block";

    // 视觉反馈：将表单移动到当前回复按钮下方
    btn.insertAdjacentElement("afterend", form);
    cancelBtn.style.display = "inline";
    textarea.focus();
  });

  // 2. 取消回复（回到主文章回复状态）
  cancelBtn.addEventListener("click", () => {
    parentIdInput.value = ""; // 清空，表示回复主文章
    textarea.value = "";
    replyTitle.innerText = "";
    document.getElementById("comment-section")?.appendChild(form); // 移回底部
    replyTitle.style.display = "none";
    cancelBtn.style.display = "none";
  });

  function clearErrors() {
    globalError!.style.display = "none";
    globalError!.innerText = "";
    document.querySelectorAll(".error").forEach((el) => {
      if (el.id !== "global-error") el.innerHTML = "";
    });
  }

  function showFieldError(fieldName: string, messages: string[]) {
    const errorEl = document.getElementById(`error-${fieldName}`);
    if (errorEl) {
      errorEl.innerText = messages.join(", ");
    }
  }
</script>

<style>
  /* 样式保持不变，略微增加一些 display 控制的平滑过渡 */
  .comment-section {
    max-width: 600px;
    margin: 2rem 0;
    padding: 1.5rem;
    border: 1px solid #eee;
    border-radius: 8px;
  }
  .form-group {
    margin-bottom: 1rem;
  }
  label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: bold;
  }
  input,
  textarea {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid #ccc;
    border-radius: 4px;
  }
  button {
    background-color: #333;
    color: white;
    padding: 0.5rem 1rem;
    border: none;
    cursor: pointer;
  }
  button:disabled {
    background-color: #999;
    cursor: not-allowed;
  }
  .error {
    color: red;
    font-size: 0.875rem;
    margin-top: 0.25rem;
    min-height: 1.2em; /* 预留位置防止抖动 */
  }
</style>
