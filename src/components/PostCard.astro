---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { AUTHOR, AUTHOR_CN } from "../consts.ts";
import type { WeatherName } from "../utils/weather";
import CommentCount from "./CommentCount.astro";
import FormattedDate from "./FormattedDate.astro";
import Weather from "./Weather.astro";

type Props = {
  post: CollectionEntry<"blog">;
  isInPostPage?: boolean;
  isExcerpt?: boolean;
};

const { post, isInPostPage = false, isExcerpt = false } = Astro.props;

const { Content } = await render(post);
---

<article class=`post-card${isInPostPage ? " in-post-page" : ""}`>
  {
    !isExcerpt && isInPostPage && (
      <Weather weather={post.data.weather as WeatherName} />
    )
  }
  {
    !isExcerpt && !isInPostPage && (
      <a href={`/${post.id}`}>
        <Weather weather={post.data.weather as WeatherName} />
      </a>
    )
  }
  <div class="post-content">
    <header>
      <h2 class="post-title">
        <span class="post-title-slash">//</span>
        {
          isInPostPage ? (
            <>{post.data.title}</>
          ) : (
            <a href={`/${post.id}`}>{post.data.title}</a>
          )
        }
      </h2>
    </header>
    <div class="post-meta">
      POSTED ON
      <a href={`/${post.id}`}>
        <FormattedDate date={post.data.pubDate} />
      </a>
      // BY {AUTHOR} // IN
      <a
        href={`/category/${(post.data.category ?? "").toLowerCase().replace(" ", "-")}`}
      >
        {post.data.category}
      </a>
      //
      <a href={`/${post.id}#comments`}>
        <CommentCount postSlug={post.id} server:defer /> 评论
      </a>
    </div>
    <div class=`markdown-content${isExcerpt ? " post-excerpt" : ""}` }>
      <Content />
      {
        isInPostPage && (
          <p class="post-signature">
            {AUTHOR_CN}
            <FormattedDate date={post.data.pubDate} showLunar />
            书于{post.data.location}
          </p>
        )
      }
    </div>
    {
      !isInPostPage && (
        <p>
          <a href={`/${post.id}`} class="btn-read">
            阅读全文 »
          </a>
        </p>
      )
    }
  </div>
</article>

<style>
  /* Post & Content */
  .post-card {
    border-bottom: 1px solid var(--container-bg);
    margin-bottom: 0;
    background: var(--cell-bg);
    padding-bottom: 20px;
  }
  .post-card.in-post-page {
    border-bottom-style: dotted;
  }
  .post-card:last-child {
    border-bottom: none;
  }
  .post-content {
    padding: 15px 20px 0 20px;
  }
  .post-title {
    font-family: var(--font-pixel10);
    font-size: 20px;
    letter-spacing: 2px;
    color: var(--text-main);
    margin-bottom: 6px;
  }
  .post-title a {
    color: var(--text-main);
  }
  .post-title a:hover {
    color: var(--highlight);
  }
  .post-title-slash {
    letter-spacing: -2px;
    color: var(--canvas-accent);
  }
  .post-meta {
    font-size: 9px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    margin-bottom: 10px;
  }
  .post-meta a:last-child {
    font-family: var(--font-pixel12);
  }
  .btn-read {
    display: inline-block;
    background: var(--cell-bg);
    border: 1px solid var(--container-bg);
    color: var(--text-main);
    padding: 3px 8px;
    font-family: var(--font-pixel10);
    font-size: 10px;
    cursor: pointer;
    box-shadow: 1px 1px 0 var(--container-bg);
  }
  .btn-read:hover {
    background: var(--highlight);
    border-color: var(--border-color);
    color: var(--highlight-text);
    box-shadow: 1px 1px 0 var(--border-color);
  }
  .post-signature {
    text-align: right;
  }
  .post-excerpt {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .post-excerpt :global(p:first-child) {
    margin-top: 0;
  }
</style>
